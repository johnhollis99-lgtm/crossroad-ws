PORT=3001

# Supabase — use service role key for server-side inserts (not the anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=


# xAI / Grok — same API key used by the Expo client
XAI_API_KEY=
# Anthropic — used by the narration generation route (Claude for narration text)
ANTHROPIC_API_KEY=

# Google Cloud TTS — path to service account JSON (same as scripts/.env)
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
