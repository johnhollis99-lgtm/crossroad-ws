# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment / Secrets ────────────────────────────────────────────────────
# Root .env holds API keys — never commit
.env
.env.local
.env.*.local
# Server runtime secrets
server/.env

# ── Expo ─────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native builds ────────────────────────────────────────────────────────────
/ios
/android
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ── Metro ────────────────────────────────────────────────────────────────────
.metro-health-check*

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Next.js (admin/) ─────────────────────────────────────────────────────────
admin/.next/
admin/out/

# ── Scripts: caches and generated audio ──────────────────────────────────────
scripts/poi-import/cache/
scripts/narrative-extraction/cache/
scripts/voice-audition/output/
scripts/audition-output/
scripts/narration-preview/output/
*.opus

# ── One-off utility scripts ───────────────────────────────────────────────────
scripts/verify-migrations.mjs

# ── Session-scoped working notes ──────────────────────────────────────────────
docs/alignment-plan.md
docs/codebase-audit.md

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# ── Local config / Supabase CLI temp ─────────────────────────────────────────
.claude/scheduled_tasks.lock
.claude/settings.local.json
supabase/.temp/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Certs ────────────────────────────────────────────────────────────────────
*.pem
